{
  "name": "@bpinternal/overwatch",
  "version": "0.2.0",
  "description": "Headless library for building control loops: scheduled bots that scan a repo for a class of anomaly, fix a few instances with a coding agent, and open a PR — no server, UI, or persistent process.",
  "keywords": [
    "control-loop",
    "coding-agent",
    "automation",
    "codemod",
    "github",
    "pull-request",
    "ci",
    "daytona",
    "claude",
    "codex"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/botpress/packages.git"
  },
  "bugs": {
    "url": "https://github.com/botpress/packages/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm run build:types && pnpm run bundle",
    "build:types": "tsc -p ./tsconfig.build.json",
    "bundle": "ts-node -T build.ts",
    "check:type": "tsc --noEmit",
    "test": "vitest --run",
    "prepublishOnly": "pnpm run check:type && pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.25.10",
    "glob": "^9.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@daytona/sdk": "^0.195.0",
    "@octokit/auth-app": "^8.2.0",
    "commander": "^15.0.0",
    "octokit": "^5.0.5"
  }
}
