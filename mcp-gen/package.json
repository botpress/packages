{
  "name": "@bpinternal/mcp-gen",
  "version": "0.1.0",
  "description": "Generate Botpress integrations from MCP servers",
  "type": "module",
  "main": "dist/api.js",
  "types": "dist/api.d.ts",
  "bin": {
    "mcp-gen": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./cli": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config-manager.d.ts",
      "import": "./dist/config-manager.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts src/api.ts src/config-manager.ts src/validators.ts --format esm --dts --clean",
    "watch": "tsup src/index.ts --format esm --dts --watch",
    "check:type": "tsc --noEmit",
    "check:format": "prettier --check .",
    "generate": "node dist/index.js",
    "prepublishOnly": "pnpm build && pnpm type-check"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.2.2",
    "@botpress/cli": "^5.5.3",
    "@botpress/sdk": "^5.4.0",
    "@bpinternal/zui": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.3",
    "eventsource": "^4.1.0",
    "node-fetch": "^3.3.2",
    "zod-to-json-schema": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}